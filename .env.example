# Copy to .env and fill with your Supabase project values.

# Public (exposed to the browser and also reused by server code):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server only (Vercel Functions - NEVER expose the service_role key):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
